# Copy to .env at the repo root (both servers read it in dev). Never commit .env.

# ── database ──────────────────────────────────────────────────────────────
# Local dev: any running MongoDB. Production: a free MongoDB Atlas URI.
MONGODB_URI=mongodb://127.0.0.1:27017/penny

# ── auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-something-long-and-random
# Shared secret between the Node API and the AI service (any random string)
SERVICE_TOKEN=change-me-too

# ── service wiring (defaults work for local dev) ──────────────────────────
PORT=4001
AI_URL=http://localhost:8400
NODE_API_URL=http://localhost:4001

# ── the brain ─────────────────────────────────────────────────────────────
# 'scripted' runs a deterministic dev model: every feature works end-to-end
# (tools, live dashboard, approvals) with canned language and NO API key.
# For the real thing, pick a model and set its key:
#   PENNY_MODEL=google_genai:gemini-3-flash-preview   + GOOGLE_API_KEY  (free at https://aistudio.google.com)
#   PENNY_MODEL=openai:gpt-4.1-mini                   + OPENAI_API_KEY
PENNY_MODEL=scripted
GOOGLE_API_KEY=
OPENAI_API_KEY=
# Multi-agent team (Penny + Bookkeeper + Analyst). Set false for a single agent.
PENNY_MULTI_AGENT=true

# ── optional integrations ─────────────────────────────────────────────────
# Google sign-in button: OAuth Web Client ID from console.cloud.google.com
GOOGLE_CLIENT_ID=
# Real Gmail sending via Composio (https://composio.dev — free tier).
# Without it, approved emails are saved to the in-app outbox as 'simulated'.
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=default

# ── observability (optional) ──────────────────────────────────────────────
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=penny
